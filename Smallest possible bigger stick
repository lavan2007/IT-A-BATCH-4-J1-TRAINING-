import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();
        int sum = 0;

        int[] a = new int[n];

        for(int i = 0; i < n; i++) {
            a[i] = sc.nextInt();
        }

        // Take adjacent pairs
        for(int i = 0; i < n; i += 2) {
            sum += Math.min(a[i], a[i + 1]);
        }

        System.out.println(sum);
    }
}
