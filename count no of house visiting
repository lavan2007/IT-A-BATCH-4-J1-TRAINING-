import java.util.Scanner;

public class HouseVisit {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        int houses, sum = 0;

        System.out.println("Enter number of houses:");
        houses = sc.nextInt();

        int[] arr = new int[houses];

        System.out.println("Enter house values:");

        for(int i = 0; i < houses; i++) {
            arr[i] = sc.nextInt();
        }

        // Visiting alternate houses
        for(int i = 0; i < houses; i = i + 2) {
            sum = sum + arr[i];
        }

        System.out.println("Total value collected: " + sum);
    }
}
